                  "width": 2,
                  "height": "fill_container"
                },
                {
                  "type": "text",
                  "id": "dSDWI",
                  "fill": "#9A9AA2",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "A sentence is a small room you build for a thought to sit quietly in.",
                  "lineHeight": 1.6,
                  "fontFamily": "Charter",
                  "fontSize": 18,
                  "fontStyle": "italic"
                }
              ]
            },
            {
              "type": "text",
              "id": "b53km",
              "name": "p3",
              "fill": "#D8D8DC",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Three things I try to keep near when I work:",
              "lineHeight": 1.65,
              "fontFamily": "Charter",
              "fontSize": 18
            },
            {
