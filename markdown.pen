                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "GMoMh",
                      "fill": "#2A2A2E",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "a cup of something warm, to mark the hour",
                      "lineHeight": 1.6,
                      "fontFamily": "Charter",
                      "fontSize": 18,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
