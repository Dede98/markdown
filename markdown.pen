                {
                  "type": "text",
                  "id": "m4jEc",
                  "fill": "#6A6A72",
                  "content": "Saved locally",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "rectangle",
              "id": "Hk3dm",
              "fill": "#44444A",
              "width": 48,
              "height": 1
            },
            {
              "type": "text",
              "id": "Ga2xK",
              "fill": "#D8D8DC",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "There is a particular quality to the hour before everyone else wakes. The house is still speaking in the low voice it uses when no one is listening, and the windows have not yet been asked to carry any light.",
              "lineHeight": 1.65,
              "fontFamily": "Charter",
              "fontSize": 18
            },
            {
              "type": "text",
              "id": "CZMF8",
              "fill": "#E8E8EC",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Morning light",
              "lineHeight": 1.3,
              "fontFamily": "Charter",
              "fontSize": 24,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "Rbgi9",
              "name": "p2",
              "fill": "#D8D8DC",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "It arrives diagonally at first, finding the spine of a book on the desk and then, as if it has remembered its manners, filling the whole room evenly. I used to write in the evening; now I wait for this.",
              "lineHeight": 1.65,
              "fontFamily": "Charter",
              "fontSize": 18
            },
            {
              "type": "frame",
              "id": "B57G3",
              "name": "quote",
              "width": "fill_container",
              "fill": "#00000000",
              "gap": 20,
              "children": [
                {
                  "type": "rectangle",
                  "id": "bSQFX",
                  "fill": "#44444A",
                  "width": 2,
                  "height": "fill_container"
                },
                {
                  "type": "text",
                  "id": "LN8Bc",
                  "fill": "#9A9AA2",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "A sentence is a small room you build for a thought to sit quietly in.",
                  "lineHeight": 1.6,
                  "fontFamily": "Charter",
                  "fontSize": 18,
                  "fontStyle": "italic"
                }
              ]
            },
            {
              "type": "text",
              "id": "ZE7cP",
              "name": "p3",
              "fill": "#D8D8DC",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Three things I try to keep near when I work:",
              "lineHeight": 1.65,
              "fontFamily": "Charter",
              "fontSize": 18
            },
            {
              "type": "frame",
              "id": "iT1kc",
