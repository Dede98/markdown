              "width": 48,
              "height": 1
            },
            {
              "type": "text",
              "id": "WYPwt",
              "fill": "#D8D8DC",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "There is a particular quality to the hour before everyone else wakes. The house is still speaking in the low voice it uses when no one is listening, and the windows have not yet been asked to carry any light.",
              "lineHeight": 1.65,
              "fontFamily": "Charter",
              "fontSize": 18
            },
            {
              "type": "text",
              "id": "VV2Z8",
              "fill": "#E8E8EC",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Morning light",
              "lineHeight": 1.3,
              "fontFamily": "Charter",
              "fontSize": 24,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "syGVN",
              "name": "p2",
              "fill": "#D8D8DC",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "It arrives diagonally at first, finding the spine of a book on the desk and then, as if it has remembered its manners, filling the whole room evenly. I used to write in the evening; now I wait for this.",
              "lineHeight": 1.65,
              "fontFamily": "Charter",
              "fontSize": 18
            },
            {
              "type": "frame",
              "id": "3fbI1",
              "name": "quote",
              "width": "fill_container",
              "fill": "#00000000",
              "gap": 20,
              "children": [
                {
                  "type": "rectangle",
                  "id": "HnGB3",
