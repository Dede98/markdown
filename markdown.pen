                  "id": "u4TAO",
                  "fill": "#5E5E66",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "A sentence is a small room you build for a thought to sit quietly in.",
                  "lineHeight": 1.6,
                  "fontFamily": "Charter",
                  "fontSize": 18,
                  "fontStyle": "italic"
                }
              ]
            },
