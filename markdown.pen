                    {
                      "type": "text",
                      "id": "bDB0T",
                      "fill": "#D8D8DC",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "So the discipline isn't really about focus. It's about tolerance — staying long enough in one idea that something quieter than your first impulse has time to arrive.",
                      "lineHeight": 1.6,
                      "fontFamily": "Charter",
                      "fontSize": 17
                    }
                  ]
