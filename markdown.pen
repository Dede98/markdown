                  "name": "DocBody",
                  "width": 640,
                  "fill": "#00000000",
                  "layout": "vertical",
                  "gap": 20,
                  "children": [
                    {
                      "type": "text",
                      "id": "1XRjZ",
                      "fill": "#D8D8DC",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "On Attention",
                      "lineHeight": 1.2,
                      "fontFamily": "Charter",
                      "fontSize": 34,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "ubmYf",
                      "fill": "#6A6A72",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Draft · April 24, 2026 · 4 min read",
                      "fontFamily": "Inter",
                      "fontSize": 12
                    },
                    {
                      "type": "frame",
                      "id": "9LdKA",
                      "width": "fill_container",
                      "height": 8,
                      "fill": "#00000000"
                    },
                    {
                      "type": "text",
                      "id": "X3NLX",
                      "fill": "#D8D8DC",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "I've been thinking about what it means to pay attention. There's a kind of looking that is really waiting — waiting for the thing to declare itself. Reading, when it is any good, is like that too.",
                      "lineHeight": 1.6,
                      "fontFamily": "Charter",
                      "fontSize": 17
                    },
                    {
                      "type": "frame",
                      "id": "Sza3r",
                      "name": "Highlight1",
                      "width": "fill_container",
                      "fill": "#283048",
                      "cornerRadius": 3,
                      "layout": "vertical",
                      "padding": [
                        8,
                        14
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "mSJK9",
                          "fill": "#D8D8DC",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Trust that the words you don't have yet are still coming.",
                          "lineHeight": 1.6,
                          "fontFamily": "Charter",
                          "fontSize": 17,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "MrifT",
                      "fill": "#D8D8DC",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "A page is a small room. You can furnish it sparely and let it breathe, or you can crowd it and call that thoroughness.",
                      "lineHeight": 1.6,
                      "fontFamily": "Charter",
                      "fontSize": 17
                    },
                    {
                      "type": "frame",
                      "id": "y4vHV",
                      "name": "Highlight2",
                      "width": "fill_container",
                      "fill": "#283048",
                      "cornerRadius": 3,
                      "layout": "vertical",
                      "padding": [
                        8,
                        14
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "YH8iP",
                          "fill": "#D8D8DC",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The second kind of page is much harder to sit in.",
                          "lineHeight": 1.6,
                          "fontFamily": "Charter",
                          "fontSize": 17,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        }
