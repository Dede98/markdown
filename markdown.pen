                  "width": 640,
                  "fill": "#00000000",
                  "layout": "vertical",
                  "gap": 20,
                  "children": [
                    {
                      "type": "text",
                      "id": "HJkWh",
                      "fill": "#2A2A2E",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "On Attention",
                      "lineHeight": 1.2,
                      "fontFamily": "Charter",
                      "fontSize": 34,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "2LC8g",
                      "fill": "#9A9AA2",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Draft · April 24, 2026 · 4 min read",
                      "fontFamily": "Inter",
                      "fontSize": 12
                    },
                    {
                      "type": "frame",
                      "id": "ra8cf",
                      "width": "fill_container",
                      "height": 8,
                      "fill": "#00000000"
                    },
                    {
                      "type": "text",
                      "id": "jKlFA",
                      "fill": "#2A2A2E",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "I've been thinking about what it means to pay attention. There's a kind of looking that is really waiting — waiting for the thing to declare itself. Reading, when it is any good, is like that too.",
                      "lineHeight": 1.6,
                      "fontFamily": "Charter",
                      "fontSize": 17
                    },
                    {
                      "type": "frame",
                      "id": "1ES09",
                      "name": "Highlight1",
                      "width": "fill_container",
                      "fill": "#EEF2FB",
                      "cornerRadius": 3,
                      "layout": "vertical",
                      "padding": [
                        8,
                        14
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "IZgjc",
                          "fill": "#2A2A2E",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Trust that the words you don't have yet are still coming.",
                          "lineHeight": 1.6,
                          "fontFamily": "Charter",
                          "fontSize": 17,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "h3ID4",
                      "fill": "#2A2A2E",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "A page is a small room. You can furnish it sparely and let it breathe, or you can crowd it and call that thoroughness.",
                      "lineHeight": 1.6,
                      "fontFamily": "Charter",
                      "fontSize": 17
                    },
                    {
                      "type": "frame",
                      "id": "0gmwX",
                      "name": "Highlight2",
                      "width": "fill_container",
                      "fill": "#EEF2FB",
                      "cornerRadius": 3,
                      "layout": "vertical",
                      "padding": [
                        8,
                        14
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "ZQY20",
                          "fill": "#2A2A2E",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The second kind of page is much harder to sit in.",
                          "lineHeight": 1.6,
                          "fontFamily": "Charter",
                          "fontSize": 17,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "31tVx",
                      "fill": "#2A2A2E",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "So the discipline isn't really about focus. It's about tolerance — staying long enough in one idea that something quieter than your first impulse has time to arrive.",
                      "lineHeight": 1.6,
                      "fontFamily": "Charter",
                      "fontSize": 17
                    }
                  ]
                },
