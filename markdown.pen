          "children": [
            {
              "type": "text",
              "id": "S4LAr",
              "fill": "#1A1A1E",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "On the Quiet Hour",
              "lineHeight": 1.15,
              "fontFamily": "Charter",
              "fontSize": 42,
              "fontWeight": "700",
              "letterSpacing": -0.5
            },
            {
              "type": "frame",
              "id": "0a9dQ",
