              "fill": "#00000000",
              "gap": 8,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "mwmqY",
                  "fill": "#9A9AA2",
                  "content": "Draft",
                  "fontFamily": "Inter",
